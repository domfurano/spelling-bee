{
    "compilerOptions": {
      "target": "ES2020",
      "module": "ES2020",
      "moduleResolution": "node",
      "strict": true,
      "removeComments": true,
      "preserveConstEnums": true,
      "resolveJsonModule": true,
      "allowSyntheticDefaultImports": true,
      "outDir": "lib",
      "sourceMap": true,
      "declaration": true,
      "lib": ["ES2020", "DOM", "DOM.Iterable"],
      "types": ["mocha"]
    },
    "include": ["src/**/*"],
    "exclude": ["./node_modules", "**/*.spec.ts"]
  }